# =============================================================================
# AfriLION Project - Environment Variables Template
# Copy this file to .env and fill in your secrets.
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- Hugging Face ---
# Get your token from https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_write_token_here
HF_ORG=LocaleNLP

# --- Weights & Biases (W&B) ---
# Get your API key from https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=afrilion
WANDB_ENTITY=localenlp

# --- Google Cloud (TPU / Storage) ---
GCP_PROJECT_ID=afrilion-49361e
GCP_ZONE=us-central2-b
GCP_BUCKET_NAME=gs://afrilion-tpu-afrilion-49361e

# --- Label Studio (Data Annotation) ---
LABEL_STUDIO_URL=http://your-label-studio-instance:8080
LABEL_STUDIO_API_KEY=your_label_studio_key_here

# --- Claude Code CLI ---
# Claude Code uses your system's Anthropic credentials. 
# You can set this if you want to override the default model.
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=your_anthropic_key_here (optional, usually managed via 'claude auth')

# --- Monitoring & Alerts ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
